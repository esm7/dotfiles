"nmap <Leader>af :AvanteFocus<CR>

nmap <Leader>aa :CodeCompanion 
vmap <Leader>aa :CodeCompanion 
nmap <Leader>ac :CodeCompanionChat<CR>

set noautochdir
set signcolumn=yes:1
set noshowmode

